# Copy to passwords.yaml and set real values. Do not commit passwords.yaml.
# Used by the server to connect to database and Redis, and for auth (JWT + email).
#
# Production: use strong, unique passwords (e.g. from a secrets manager or
# generated with openssl rand -base64 24). Never use defaults or commit this file.
#
# Auth (email login/register):
#   jwtRefreshTokenHashPepper:  openssl rand -base64 32
#   jwtHmacSha512PrivateKey:   openssl rand -base64 64   (must be valid HMAC SHA-512 key)
#   emailSecretHashPepper:     openssl rand -base64 32   (min 10 chars)

development:
  databasePassword: postgres
  # redis: <password>   # if Redis has a password
  jwtRefreshTokenHashPepper: change-me-use-openssl-rand-base64-32
  jwtHmacSha512PrivateKey: change-me-use-openssl-rand-base64-64
  emailSecretHashPepper: change-me-use-openssl-rand-base64-32

# production:
#   databasePassword: <from-secrets-manager-or-env>
#   redis: <from-secrets-manager-or-env>
#   jwtRefreshTokenHashPepper: <from-secrets>
#   jwtHmacSha512PrivateKey: <from-secrets>
#   emailSecretHashPepper: <from-secrets>
