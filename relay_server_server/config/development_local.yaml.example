# Copy to development.yaml to run WITHOUT Postgres or Docker.
# Workspace data is stored in memory (set env RELAY_USE_IN_MEMORY=1).
# Data is lost when the server stops.

apiServer:
  port: 8080
  publicHost: localhost
  publicPort: 8080
  publicScheme: http

# Required for the /workspace REST route (Röle client).
webServer:
  port: 8082
  publicHost: localhost
  publicPort: 8082
  publicScheme: http

# No database or redis - omit them so the server starts without them.
