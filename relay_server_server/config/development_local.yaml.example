# Minimal local template without external services.
# NOTE: the rebuilt backend is database-backed; this file is only useful for
# smoke startup scenarios and not for full feature execution.

apiServer:
  port: 8080
  publicHost: localhost
  publicPort: 8080
  publicScheme: http

webServer:
  port: 8082
  publicHost: localhost
  publicPort: 8082
  publicScheme: http

# database and redis intentionally omitted in this minimal template.
