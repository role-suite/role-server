# Copy to .env and set values. Do not commit .env.
# Used when running the server (e.g. RELAY_* variables).

# Optional. Comma-separated list of valid API keys (Bearer tokens).
# When set, clients must send one of these in Authorization: Bearer <key>.
# Each key maps to a distinct user id (1 = first key, 2 = second, etc.).
# Example: RELAY_API_KEYS=my-secret-key,another-key
# RELAY_API_KEYS=

# Optional. Set to 1 or true to use in-memory storage (no Postgres). For local dev only.
# RELAY_USE_IN_MEMORY=0
